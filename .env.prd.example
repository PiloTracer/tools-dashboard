# Tools Dashboard — production-style compose (.env.prd)
# Copy: cp .env.prd.example .env.prd
# Run:  docker compose -f docker-compose.prd.yml --env-file .env.prd up -d
# Or:   TD_ENV=prd ./bin/start.sh  (uses .env.prd when present)

COMPOSE_PROJECT_NAME=tools_dashboard_prd

# --- Edge / public URLs (required for real deployments) ---
PUBLIC_APP_BASE_URL=https://your-domain.example/app
BACK_AUTH_BASE_URL=https://your-domain.example/auth

# Internal URLs (defaults match docker-compose service DNS names)
FRONT_INTERNAL_BACK_API_URL=http://back-api:8000
FRONT_INTERNAL_BACK_AUTH_URL=http://back-auth:8001
FRONT_INTERNAL_WEBSOCKET_URL=ws://back-websockets:8010

# Nginx HTTP on host (container still listens on :80 inside). Default 8082 — no host :80.
NGINX_HTTP_PORT=8082

# --- PostgreSQL (must match *_DATABASE_URL credentials below) ---
POSTGRES_DB=main_db
POSTGRES_USER=toolsdash
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# URL-encode special characters in passwords (e.g. @ -> %40)
BACK_API_DATABASE_URL=postgresql://toolsdash:CHANGE_ME_STRONG_PASSWORD@postgresql:5432/main_db
BACK_AUTH_DATABASE_URL=postgresql+asyncpg://toolsdash:CHANGE_ME_STRONG_PASSWORD@postgresql:5432/main_db
FEATURE_REGISTRY_DATABASE_URL=postgresql://toolsdash:CHANGE_ME_STRONG_PASSWORD@postgresql:5432/main_db
BACK_POSTGRES_SERVICE_DATABASE_URL=postgresql://toolsdash:CHANGE_ME_STRONG_PASSWORD@postgresql:5432/main_db

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
BACK_AUTH_REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
API_BASE_URL=http://back-api:8000
AUTH_SERVICE_URL=http://back-auth:8001
FEATURE_REGISTRY_URL=http://feature-registry:8005

# --- Cassandra ---
CASSANDRA_CONTACT_POINTS=cassandra
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=tools_dashboard
CASSANDRA_CLUSTER_NAME=tools_cluster

# --- Auth cookies (use true behind HTTPS) ---
SESSION_COOKIE_SECURE=true
REGISTRATION_CSRF_COOKIE_SECURE=true
SESSION_COOKIE_DOMAIN=.your-domain.example
REGISTRATION_CSRF_COOKIE_DOMAIN=.your-domain.example

# --- SMTP (replace MailHog from dev) ---
MAIL_HOST=smtp.your-provider.example
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SENDER=no-reply@your-domain.example
MAIL_USE_TLS=true

# --- Secrets (generate before go-live) ---
JWT_SECRET_KEY=
DEFAULT_ADMIN_EMAIL=admin@your-domain.example
DEFAULT_ADMIN_PASSWORD=

# --- OAuth (optional) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.example/app/features/user-registration/verify?provider=google

# --- SeaweedFS S3 API hostname advertised to clients ---
SEAWEEDFS_S3_DOMAIN_NAME=your-domain.example
