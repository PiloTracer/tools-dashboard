# =============================================================================
# Tools Dashboard — PRODUCTION (.env.prd)
# =============================================================================
# Copy:  cp .env.prd.example .env.prd
# Edit:  set secrets, passwords, and URLs for tools.aiepic.app
# Run:   docker compose -f docker-compose.prd.yml --env-file .env.prd up -d --build
# Or:    TD_ENV=prd ./bin/start.sh prd up-build
#
# Pre-flight checklist:
#   [ ] After any package.json change in front-admin / front-public: run npm install and commit package-lock.json (Docker uses npm ci).
#   [ ] DNS A/AAAA: tools.aiepic.app → host running Docker
#   [ ] TLS: terminate at CDN/LB OR add certs to nginx (see infra/nginx/README.prd.md)
#   [ ] Google OAuth: Authorized redirect URI = GOOGLE_OAUTH_REDIRECT_URI below (exact string)
#   [ ] JWT_SECRET_KEY: openssl rand -base64 48
#   [ ] OAUTH_CONSENT_SERVICE_SECRET: openssl rand -hex 32 (same value as in this file only)
#   [ ] POSTGRES_PASSWORD + matching URLs (URL-encode special chars in JDBC strings)
#   [ ] DEFAULT_ADMIN_PASSWORD: strong password (first boot creates admin)
#   [ ] Cookie domains: .tools.aiepic.app (leading dot = all subdomains)
# =============================================================================

COMPOSE_PROJECT_NAME=tools_dashboard_prd

# --- Public URLs (browser + email links + JWT issuer context) ---
# Used by back-auth for verification links and OAuth issuer; must match how users reach the site.
PUBLIC_APP_BASE_URL=https://tools.aiepic.app/app

# Remix loaders call back-auth from *inside* Docker — keep the internal service URL (not the public https URL).
BACK_AUTH_BASE_URL=http://back-auth:8001

# Internal service URLs (defaults match Docker DNS; normally leave as-is)
FRONT_INTERNAL_BACK_API_URL=http://back-api:8000
FRONT_INTERNAL_BACK_AUTH_URL=http://back-auth:8001
FRONT_INTERNAL_WEBSOCKET_URL=ws://back-websockets:8010

# Host port published for nginx HTTP (8082 avoids host :80 conflicts; use 80 behind a dedicated LB)
NGINX_HTTP_PORT=8082

# Optional: printed after `./bin/start.sh prd up` so operators see the canonical browser URL
TD_PUBLIC_BASE_URL=https://tools.aiepic.app

# --- PostgreSQL ---
POSTGRES_DB=main_db
POSTGRES_USER=toolsdash
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# URL-encode special characters in passwords (e.g. @ → %40)
BACK_API_DATABASE_URL=postgresql://toolsdash:CHANGE_ME_STRONG_PASSWORD@postgresql:5432/main_db
BACK_AUTH_DATABASE_URL=postgresql+asyncpg://toolsdash:CHANGE_ME_STRONG_PASSWORD@postgresql:5432/main_db
FEATURE_REGISTRY_DATABASE_URL=postgresql://toolsdash:CHANGE_ME_STRONG_PASSWORD@postgresql:5432/main_db
BACK_POSTGRES_SERVICE_DATABASE_URL=postgresql://toolsdash:CHANGE_ME_STRONG_PASSWORD@postgresql:5432/main_db

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
BACK_AUTH_REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
API_BASE_URL=http://back-api:8000
AUTH_SERVICE_URL=http://back-auth:8001
FEATURE_REGISTRY_URL=http://feature-registry:8005

# --- Cassandra ---
CASSANDRA_CONTACT_POINTS=cassandra
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=tools_dashboard
CASSANDRA_CLUSTER_NAME=tools_cluster

# --- Cookies (HTTPS in production) ---
SESSION_COOKIE_SECURE=true
REGISTRATION_CSRF_COOKIE_SECURE=true
SESSION_COOKIE_DOMAIN=.tools.aiepic.app
REGISTRATION_CSRF_COOKIE_DOMAIN=.tools.aiepic.app

# --- SMTP ---
MAIL_HOST=smtp.your-provider.example
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SENDER=no-reply@tools.aiepic.app
MAIL_USE_TLS=true

# --- Application secrets (required; compose fails on empty — replace before go-live) ---
JWT_SECRET_KEY=CHANGE_ME_use_openssl_rand_base64_48

DEFAULT_ADMIN_EMAIL=admin@tools.aiepic.app
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_strong_password_min_12_chars

# --- Google sign-in (optional) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://tools.aiepic.app/app/features/user-registration/verify

# --- Ecosystem OAuth (silent authorize by default) ---
OAUTH_CONSENT_SERVICE_SECRET=
OAUTH_REQUIRE_INTERACTIVE_CONSENT_UI=

# --- SeaweedFS S3 hostname advertised to clients ---
SEAWEEDFS_S3_DOMAIN_NAME=tools.aiepic.app
