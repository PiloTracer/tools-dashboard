# =============================================================================
# Tools Dashboard — unified key order
# =============================================================================
# Same line number = same variable. Only values (after the first =) may differ.
# Files: .env.dev.example, .env, .env.prd.example, .env.prd
# =============================================================================

# --- stack / compose: unique stack id = TD_STACK_BASE (default tools_dashboard) + TD_STACK_SUFFIX ---
# Full suffix: _<env>_<app_code> e.g. _dev_tds, _prd_tds. Override for multiple clones: _dev_tds2
TD_APP_CODE=tds
TD_STACK_SUFFIX=_dev_tds
COMPOSE_PROJECT_NAME=tools_dashboard_dev_tds

# --- ecosystem OAuth (back-api, front-public; silent authorize by default) ---
OAUTH_CONSENT_SERVICE_SECRET=tools-dashboard-oauth-consent-dev
OAUTH_REQUIRE_INTERACTIVE_CONSENT_UI=

# --- Remix: paths & server-side back-auth (Docker internal DNS) ---
PUBLIC_APP_BASE_PATH=/app
BACK_AUTH_BASE_URL=http://back-auth:8001
FRONT_INTERNAL_BACK_API_URL=http://back-api:8000
FRONT_INTERNAL_BACK_AUTH_URL=http://back-auth:8001
FRONT_INTERNAL_WEBSOCKET_URL=ws://back-websockets:8010
NGINX_HTTP_PORT=8082
# TLS: terminate HTTPS at host or CDN; keep TD_PUBLIC_BASE_URL in sync with browser entry (see infra/nginx/).
TD_PUBLIC_BASE_URL=https://dev.aiepic.app
# Node (Remix in front-admin / front-public): optional path to a PEM CA bundle inside the container when
# TD_PUBLIC_BASE_URL (or browser flows) use HTTPS signed by a private CA (e.g. mkcert). Mount the file and set this.
# Leave empty for public CA chains. Python services (back-api) do not use this variable.
NODE_EXTRA_CA_CERTS=

# --- PostgreSQL (host/credentials; must match per-service URLs below) ---
POSTGRES_DB=main_db
POSTGRES_USER=user
POSTGRES_PASSWORD=pass

# --- Per-service database URLs (sync with POSTGRES_*; URL-encode special chars in password) ---
BACK_API_DATABASE_URL=postgresql://user:pass@postgresql:5432/main_db
BACK_AUTH_DATABASE_URL=postgresql+asyncpg://user:pass@postgresql:5432/main_db
FEATURE_REGISTRY_DATABASE_URL=postgresql://user:pass@postgresql:5432/main_db
BACK_POSTGRES_SERVICE_DATABASE_URL=postgresql://user:pass@postgresql:5432/main_db

# --- single DATABASE_URL (back-auth async; used in docs / tools; same DB as above) ---
DATABASE_URL=postgresql+asyncpg://user:pass@postgresql:5432/main_db

# --- Redis & internal HTTP services (docker DNS) ---
REDIS_URL=redis://redis:6379/0
BACK_AUTH_REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
# --- Redis password (empty in dev; prd: set and use redis://:password@ in all Redis URLs) ---
REDIS_PASSWORD=
API_BASE_URL=http://back-api:8000
AUTH_SERVICE_URL=http://back-auth:8001
FEATURE_REGISTRY_URL=http://feature-registry:8005

# --- Cassandra ---
CASSANDRA_CONTACT_POINTS=cassandra
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=auth_events
CASSANDRA_CLUSTER_NAME=tools_cluster

# --- back-auth: public app URL for links (browser) ---
PUBLIC_APP_BASE_URL=https://dev.aiepic.app/app
VERIFICATION_PATH=/features/user-registration/verify
REGISTRATION_PASSWORD_MIN_LENGTH=12
REGISTRATION_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# --- session cookies ---
SESSION_COOKIE_NAME=td_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_MAX_AGE=604800
SESSION_COOKIE_DOMAIN=

# --- CSRF cookies (registration) ---
REGISTRATION_CSRF_COOKIE_SECURE=false
REGISTRATION_CSRF_COOKIE_SAMESITE=Lax
REGISTRATION_CSRF_COOKIE_MAX_AGE=900
REGISTRATION_CSRF_COOKIE_DOMAIN=

# --- Google OAuth (optional) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://dev.aiepic.app/app/features/user-registration/verify
# Space- or comma-separated Google OIDC scopes only (openid, email, profile, or full userinfo.* URLs). Do not paste prose or multi-line docs — Google returns invalid_scope for junk tokens.
GOOGLE_OAUTH_SCOPES=openid email profile
GOOGLE_OAUTH_ALLOWED_DOMAINS=
GOOGLE_OAUTH_BUTTON_TEXT=Sign in with Google

# --- SMTP (verification email: MAIL_HOST + MAIL_SENDER; dev compose uses Mailhog — see docker-compose.dev.yml) ---
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SENDER=no-reply@tools-dashboard.local
# MAIL_USE_TLS: false for plain SMTP (e.g. Mailhog :1025); true for STARTTLS (587) or implicit TLS (465).
MAIL_USE_TLS=false

# --- JWT & default admin (back-auth) ---
JWT_SECRET_KEY=your-secret-key-change-in-production-please
JWT_ALGORITHM=HS256
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=Admin123!ChangeMe
SEED_ADMIN_PROMOTE_TO_ADMIN=1

# --- SeaweedFS S3 API (must match seaweedfs-config/s3-config.json) ---
SEAWEED_S3_ACCESS_KEY=seaweedadmin
SEAWEED_S3_SECRET_KEY=^seaweedadmin!changeme!

# --- SeaweedFS S3 public hostname ---
SEAWEEDFS_S3_DOMAIN_NAME=localhost

# =============================================================================
# INTEGRITY CHECKLIST (identical line numbers in all .env* files)
# =============================================================================
# [ ] POSTGRES_PASSWORD matches all *_DATABASE_URL and DATABASE_URL
# [ ] GOOGLE_OAUTH_REDIRECT_URI matches Google Cloud Console (full URL, no ?provider=)
# [ ] OAUTH_CONSENT_SERVICE_SECRET set for app-library / ecosystem OAuth
# [ ] SESSION_* / CSRF flags: use HTTPS and secure cookies in production (.env.prd)
# [ ] SEAWEED_S3_* match seaweedfs-config/s3-config.json; rotate after clone
# [ ] Do not commit .env or .env.prd (gitignored)
